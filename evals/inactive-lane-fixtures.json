  {
    "id": "routine-progress",
    "description": "Routine progress should become one natural voicemail.",
    "input": {
      "activeProject": "Tri-State Relay Service",
      "inactiveProject": "Hamzo",
      "existingPendingMessage": null,
      "incoming": [
        {
          "type": "update",
          "priority": "normal",
          "message": "I found the failing fixture."
        },
        {
          "type": "update",
          "priority": "normal",
          "message": "I patched the parser path."
        },
        {
          "type": "update",
          "priority": "normal",
          "message": "Tests are running now."
        }
      ]
    },
    "expect": {
      "action": "replace",
      "type": "update",
      "priority": "normal",
