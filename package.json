{
  "name": "tri-state-relay-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local macOS agent relay queue with serialized speech playback.",
  "bin": {
    "relay": "./dist/src/cli.js",
    "relay-processor": "./dist/src/processor.js"
  },
  "scripts": {
    "test": "node --test --experimental-strip-types tests/**/*.test.ts && tests/macos-bundle-validation.test.sh",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:native:cli": "mkdir -p dist/native && perry compile src/cli.ts -o dist/native/relay",
    "build:native": "npm run build:native:cli && perry compile src/processor.ts -o dist/native/relay-processor",
    "build:macos": "npm run build:macos:direct",
    "build:macos:direct": "scripts/build-macos.sh direct",
    "build:macos:app-store": "scripts/build-macos.sh app-store",
    "package:macos:direct": "scripts/package-macos-direct.sh",
    "restart:macos": "scripts/restart-macos-app.sh",
    "eval:inactive-line": "scripts/eval-inactive-line.py",
    "perry:check": "perry check src/ --check-deps",
    "validate": "npm test && npm run typecheck && npm run perry:check && npm run build"
  },
  "keywords": [
    "agent",
    "relay",
    "speech",
    "macos"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@perryts/perry": "^0.5.1025",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  }
}
